source "https://rubygems.org"

# Mirrors the GitHub Pages build environment for local previews.
gem "github-pages", "~> 232", group: :jekyll_plugins
gem "jekyll-feed"
gem "jekyll-seo-tag"

# Windows and JRuby do not include zoneinfo files, so bundle the tzinfo data gem.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

# Ruby 3.4+ no longer bundles these standard-library gems that Jekyll 3.9 expects.
# Needed for local preview builds only; GitHub Pages provides its own runtime.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
gem "webrick"
